cmake_minimum_required(VERSION 3.20)

foreach(v TEST_MAP LAST_FAILED ALLOWLIST)
  if(NOT DEFINED ${v} OR "${${v}}" STREQUAL "")
    message(FATAL_ERROR "Missing required -D${v}=...")
  endif()
endforeach()

if(NOT EXISTS "${TEST_MAP}")
  message(FATAL_ERROR "Test map not found: ${TEST_MAP}")
endif()
if(NOT EXISTS "${ALLOWLIST}")
  message(FATAL_ERROR "Allowlist not found: ${ALLOWLIST}")
endif()
set(FAILED_LINES)
if(EXISTS "${LAST_FAILED}")
  file(STRINGS "${LAST_FAILED}" FAILED_LINES)
else()
  message(STATUS
    "LastTestsFailed.log not found; treating as zero failed tests: ${LAST_FAILED}")
endif()
set(FAILED_TEST_NAMES)
foreach(line IN LISTS FAILED_LINES)
  string(STRIP "${line}" line)
  if(line STREQUAL "")
    continue()
  endif()
  string(REGEX REPLACE "^[0-9]+:" "" test_name "${line}")
  list(APPEND FAILED_TEST_NAMES "${test_name}")
endforeach()
list(REMOVE_DUPLICATES FAILED_TEST_NAMES)

file(STRINGS "${TEST_MAP}" MAP_LINES)
set(FAILED_ENTRIES)
foreach(line IN LISTS MAP_LINES)
  string(STRIP "${line}" line)
  if(line STREQUAL "" OR line MATCHES "^#")
    continue()
  endif()

  string(REPLACE "\t" ";" fields "${line}")
  list(LENGTH fields fields_len)
  if(fields_len LESS 2)
    continue()
  endif()
  list(GET fields 0 test_name)
  list(GET fields 1 entry)

  list(FIND FAILED_TEST_NAMES "${test_name}" failed_idx)
  if(NOT failed_idx EQUAL -1)
    list(APPEND FAILED_ENTRIES "${entry}")
  endif()
endforeach()
list(REMOVE_DUPLICATES FAILED_ENTRIES)

file(READ "${ALLOWLIST}" ALLOWLIST_OLD_CONTENT)
file(WRITE "${ALLOWLIST}.bak" "${ALLOWLIST_OLD_CONTENT}")

string(TIMESTAMP NOW_UTC "%Y-%m-%d %H:%M:%S UTC" UTC)
set(new_content "# Auto-generated by PruneAllowlistToFailed.cmake\n")
string(APPEND new_content "# Generated at ${NOW_UTC}\n")
string(APPEND new_content "# Source: ${LAST_FAILED}\n")
foreach(entry IN LISTS FAILED_ENTRIES)
  string(APPEND new_content "${entry}\n")
endforeach()
file(WRITE "${ALLOWLIST}" "${new_content}")

list(LENGTH FAILED_TEST_NAMES FAILED_TEST_COUNT)
list(LENGTH FAILED_ENTRIES FAILED_ENTRY_COUNT)
message(STATUS
  "Updated ${ALLOWLIST}: kept ${FAILED_ENTRY_COUNT} failed entries "
  "(from ${FAILED_TEST_COUNT} failed tests). Backup: ${ALLOWLIST}.bak")
